# ==================== MEDIA FILES ====================
# Ignore all MP3 files (large audio files)
*.mp3
*.mp4
*.m4a
*.wav
*.flac
*.ogg

# Keep the media folder structure but ignore content
# If you want to track the folder, add a .gitkeep file inside

# ==================== PYTHON ====================
# Python cache and virtual environments
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# ==================== SYSTEM FILES ====================
# Windows
Thumbs.db
desktop.ini
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ==================== IDE / EDITOR ====================
# VSCode
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-snippets

# Keep workspace settings if needed
# !.vscode/settings.json

# JetBrains IDEs
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==================== LOGS & TEMP ====================
# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# ==================== NODE (if you add npm later) ====================
node_modules/
package-lock.json
yarn.lock

# ==================== BUILD / DIST ====================
dist/
build/
*.zip
*.tar.gz

# ==================== BACKUP FILES ====================
*.bak
*.backup
*.old

# ==================== SENSITIVE DATA ====================
# Environment variables (if you add any)
.env
.env.local
.env.*.local

# Private configuration (if any)
config.local.json
secrets.json

# ==================== PROJECT SPECIFIC ====================
# Keep these folders but ignore large content
# media/ is already ignored via *.mp3 pattern

# Ignore player image working files (keep only final versions)
player image/*.psd
player image/*.ai
player image/*.xcf

# Python script outputs
mp3-management/python/*.pyc
mp3-management/python/__pycache__/

# ==================== KEEP THESE ====================
# Force include important files even if they match patterns above
!.gitignore
!.gitkeep
!README.md
