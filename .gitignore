# ==================== MEDIA FILES ====================
# Ignore all audio/video files (large media files)
*.mp3
*.wma
*.wav
*.flac
*.aac
*.m4a
*.ogg
*.opus
*.mp4
*.avi
*.mkv
*.mov
*.webm

# Ignore media folder (Hugging Face clone - not part of main repo)
media/

# Ignore old hf-dataset folder (deprecated - using media instead)
hf-dataset/

# ==================== PYTHON ====================
# Python cache and virtual environments
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# ==================== SYSTEM FILES ====================
# Windows
Thumbs.db
desktop.ini
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ==================== IDE / EDITOR ====================
# VSCode
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-snippets

# JetBrains IDEs
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==================== LOGS & TEMP ====================
# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# ==================== NODE (if you add npm later) ====================
node_modules/
package-lock.json
yarn.lock

# ==================== BUILD / DIST ====================
dist/
build/
*.zip
*.tar.gz

# ==================== BACKUP FILES ====================
*.bak
*.backup
*.old

# ==================== SENSITIVE DATA ====================
# Environment variables (if you add any)
.env
.env.local
.env.*.local

# Private configuration (if any)
config.local.json
secrets.json

# ==================== PROJECT SPECIFIC ====================
# Ignore player image working files (keep only final versions)
player image/*.psd
player image/*.ai
player image/*.xcf

# Python script outputs
mp3-management/python/*.pyc
mp3-management/python/__pycache__/

# ==================== KEEP THESE ====================
# Force include important files even if they match patterns above
!.gitignore
!.gitkeep
!README.md
